    <!-- ====== SEITE 14: QUELLE 1 · EIGENE PROBLEME ====== -->
    <div class="page block-02">
      <span class="page-label">Seite 14 · Quelle 1 · Eigene Probleme</span>
      <div class="page-inner">
        <div class="page-header">
          <div class="left">2.2 · Fünf Quellen für Ideen</div>
          <div class="right">Block 02 · Zündfunke</div>
