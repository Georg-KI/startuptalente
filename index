<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<title>Startup Talente — Buchvorschau</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Barlow+Condensed:wght@700;800;900&family=DM+Serif+Display:ital@0;1&family=Caveat+Brush&display=swap" rel="stylesheet">
<style>
:root {
  /* === Block-Themen === */
  --block01-deep: #3C1A47;   --block01-accent: #B6FF00;
  --block02-deep: #001621;   --block02-accent: #FF4103;
  --block03-deep: #2872A1;   --block03-accent: #CBDDE9;
  --block04-deep: #171717;   --block04-accent: #21F1A8;
  --block05-deep: #003566;   --block05-accent: #FFC300;
  --block06-deep: #1F2140;   --block06-accent: #7C83FF;

  /* === Box-Hintergründe und Akzente === */
  --box-martin-bg: #F1E194;       --box-martin-accent: #5B0E14;
  --box-sophia-bg: #FFD2C2;       --box-sophia-accent: #789A99;
  --box-merksatz-bg: #F5F6F7;     --box-merksatz-accent: #2F2F33;
  --box-praxistipp-bg: #FFFDF1;   --box-praxistipp-accent: #59C749;
  --box-risiko-bg: #FCF6F5;       --box-risiko-accent: #C72D1B;
  --box-interview-bg: #E4DDD3;    --box-interview-accent: #00A19B;
  --box-qr-bg: #C8FAF2;           --box-qr-accent: #0F2F2F;
  --box-optional-bg: #FEFACD;     --box-optional-accent: #5F4A8B;
  --box-naechster-bg: #FFE5EC;    --box-naechster-accent: #FD1843;
  --box-fehler-bg: #FEE715;       --box-fehler-accent: #101820;

  /* === Sonstiges === */
  --beispiel-blue: #1A5276;
  --page-bg: #FFFDF8;
  --text: #1A1A1A;
  --text-muted: #555;

  /* === Typografie === */
  --font-cover: 'Caveat Brush', cursive;
  --font-heading: 'Barlow Condensed', sans-serif;
  --font-body: 'Barlow', sans-serif;
  --font-pullquote: 'DM Serif Display', serif;

  --fs-body: 15.5px;
  --fs-h-chapter: 56px;
  --fs-block-num: 110px;
  --fs-cover-title: 168px;
  --fs-pullquote: 28px;

  --scale: 1;
}

* { box-sizing: border-box; }

body {
  margin: 0;
  padding: 0;
  background: #E8E6DF;
  font-family: var(--font-body);
  color: var(--text);
  display: flex;
  min-height: 100vh;
}

/* ============ EDITOR PANEL ============ */
.editor {
  position: sticky;
  top: 0;
  width: 320px;
  height: 100vh;
  background: #1a1a1a;
  color: #f5f5f5;
  overflow-y: auto;
  flex-shrink: 0;
  font-size: 12px;
  z-index: 100;
}

.editor-header {
  padding: 18px 20px 14px;
  border-bottom: 1px solid #333;
  position: sticky;
  top: 0;
  background: #1a1a1a;
  z-index: 10;
}
.editor-header h1 {
  font-family: var(--font-heading);
  font-weight: 900;
  font-size: 16px;
  letter-spacing: 1px;
  text-transform: uppercase;
  margin: 0 0 8px;
}
.editor-header .actions {
  display: flex;
  gap: 6px;
}
.editor-header button {
  flex: 1;
  background: #2d2d2d;
  color: #f5f5f5;
  border: 1px solid #444;
  padding: 6px 8px;
  font-family: var(--font-body);
  font-size: 11px;
  cursor: pointer;
  border-radius: 3px;
}
.editor-header button:hover { background: #3d3d3d; }
.editor-header button.primary { background: #B6FF00; color: #1a1a1a; border-color: #B6FF00; font-weight: 600; }
.editor-header button.primary:hover { background: #c4ff33; }

.tab-nav {
  display: flex;
  border-bottom: 1px solid #333;
  background: #1a1a1a;
  position: sticky;
  top: 86px;
  z-index: 10;
}
.tab-nav button {
  flex: 1;
  background: transparent;
  color: #888;
  border: none;
  padding: 10px 6px;
  font-family: var(--font-body);
  font-size: 11px;
  letter-spacing: 0.5px;
  cursor: pointer;
  text-transform: uppercase;
  border-bottom: 2px solid transparent;
}
.tab-nav button.active { color: #B6FF00; border-bottom-color: #B6FF00; }

.tab-panel { display: none; padding: 14px 16px 30px; }
.tab-panel.active { display: block; }

.editor-section {
  margin-bottom: 18px;
}
.editor-section h3 {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: 11px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: #aaa;
  margin: 0 0 8px;
}

.color-row {
  display: grid;
  grid-template-columns: 1fr auto auto;
  gap: 8px;
  align-items: center;
  padding: 5px 0;
}
.color-row label {
  font-size: 11px;
  color: #ddd;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.color-row input[type="color"] {
  width: 28px;
  height: 22px;
  padding: 0;
  border: 1px solid #444;
  background: transparent;
  cursor: pointer;
  border-radius: 3px;
}
.color-row .hex-display {
  font-family: 'SF Mono', Monaco, monospace;
  font-size: 10px;
  color: #888;
  width: 60px;
  text-align: right;
}

.slider-row {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 8px;
  align-items: center;
  padding: 6px 0;
}
.slider-row label { font-size: 11px; color: #ddd; }
.slider-row input[type="range"] { grid-column: span 2; width: 100%; }
.slider-row .value { font-size: 10px; color: #888; font-family: 'SF Mono', Monaco, monospace; }

.scale-control {
  padding: 12px 16px;
  border-bottom: 1px solid #333;
  background: #222;
}
.scale-control label {
  display: block;
  font-size: 10px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: #888;
  margin-bottom: 6px;
}
.scale-control input { width: 100%; }
.scale-control .value { font-size: 10px; color: #B6FF00; font-family: 'SF Mono', Monaco, monospace; }

.export-area {
  background: #0d0d0d;
  border: 1px solid #333;
  padding: 10px;
  font-family: 'SF Mono', Monaco, monospace;
  font-size: 10px;
  color: #B6FF00;
  white-space: pre-wrap;
  max-height: 300px;
  overflow-y: auto;
  border-radius: 3px;
  margin-top: 10px;
}

/* ============ PAGES AREA ============ */
.pages-area {
  flex: 1;
  padding: 40px 30px 80px;
  overflow-x: auto;
}

.pages-intro {
  max-width: 880px;
  margin: 0 auto 30px;
  padding: 18px 22px;
  background: white;
  border-radius: 8px;
  box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  font-size: 13px;
  color: #333;
  line-height: 1.6;
}
.pages-intro strong { font-family: var(--font-heading); font-weight: 800; letter-spacing: 0.5px; }

.pages {
  display: flex;
  flex-direction: column;
  gap: 50px;
  align-items: center;
}

.page {
  width: calc(880px * var(--scale));
  height: calc(720px * var(--scale));
  background: var(--page-bg);
  box-shadow: 0 12px 40px rgba(0,0,0,0.18), 0 2px 4px rgba(0,0,0,0.08);
  position: relative;
  overflow: hidden;
  border-radius: 2px;
}
.page-inner {
  width: 880px;
  height: 720px;
  transform: scale(var(--scale));
  transform-origin: top left;
  padding: 50px 60px;
  position: relative;
  display: flex;
  flex-direction: column;
}
.page-label {
  position: absolute;
  top: -28px;
  left: 0;
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #666;
}

/* ============ TYPOGRAPHY ============ */
.h-cover { font-family: var(--font-cover); font-weight: 400; line-height: 0.95; }
.h-chapter { font-family: var(--font-heading); font-weight: 900; text-transform: uppercase; line-height: 1.0; letter-spacing: 0.5px; }
.h-sub { font-family: var(--font-heading); font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px; }
.body-text { font-family: var(--font-body); font-weight: 400; line-height: 1.55; font-size: var(--fs-body); }
.body-text p { margin: 0 0 12px; }

/* ============ SEITENKOPF und SEITENFUSS ============ */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  border-bottom: 2px solid var(--text);
  padding-bottom: 10px;
  margin-bottom: 22px;
}
.page-header .left {
  font-family: var(--font-heading);
  font-weight: 900;
  font-size: 22px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.page-header .right {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--block-deep, #888);
}

.page-footer {
  margin-top: auto;
  padding-top: 14px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
}
.page-footer .block-marker {
  display: flex;
  align-items: center;
  gap: 8px;
}
.page-footer .block-marker::before {
  content: '';
  display: inline-block;
  width: 24px;
  height: 8px;
  background: var(--block-deep, currentColor);
  border-radius: 2px;
}
.page-footer .block-marker {
  color: var(--block-deep);
}
.page-footer .page-num {
  color: var(--text-muted);
}

/* ============ COVER ============ */
.cover {
  background: var(--block01-deep);
  color: white;
}
.cover .page-inner {
  justify-content: space-between;
}
.cover-top { display: flex; justify-content: space-between; align-items: flex-start; }
.cover-eyebrow {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 14px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--block01-accent);
}
.cover-deco {
  width: 90px; height: 90px;
  background: var(--box-naechster-accent);
  border-radius: 50%;
  opacity: 0.9;
  position: relative;
}
.cover-deco::after {
  content: '';
  position: absolute;
  width: 60px; height: 60px;
  background: var(--block04-accent);
  border-radius: 50%;
  bottom: -20px; right: -30px;
  opacity: 0.85;
}
.cover-title {
  color: var(--block01-accent);
  font-size: var(--fs-cover-title);
  letter-spacing: -2px;
  margin: 0;
}
.cover-sub {
  font-family: var(--font-body);
  font-size: 22px;
  font-weight: 400;
  color: white;
  margin-top: 8px;
  max-width: 520px;
}
.cover-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 2px;
  text-transform: uppercase;
}
.cover-bar { display: flex; gap: 4px; }
.cover-bar span { width: 28px; height: 8px; }
.cover-bar span:nth-child(1){ background: var(--block01-accent); }
.cover-bar span:nth-child(2){ background: var(--block02-accent); }
.cover-bar span:nth-child(3){ background: var(--block03-accent); }
.cover-bar span:nth-child(4){ background: var(--block04-accent); }
.cover-bar span:nth-child(5){ background: var(--block05-accent); }
.cover-bar span:nth-child(6){ background: var(--block06-accent); }

/* ============ TOC ============ */
.toc-list {
  margin-top: 24px;
}
.toc-item {
  display: grid;
  grid-template-columns: 60px 1fr auto;
  gap: 20px;
  align-items: baseline;
  padding: 14px 0;
  border-bottom: 1px dashed #ccc;
}
.toc-item .num {
  font-family: var(--font-heading);
  font-weight: 900;
  font-size: 32px;
  line-height: 1;
  color: var(--toc-color, var(--text));
}
.toc-item .title-group .title {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: 22px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.toc-item .title-group .sub {
  font-family: var(--font-pullquote);
  font-style: italic;
  font-size: 14px;
  color: var(--text-muted);
  margin-top: 2px;
}
.toc-item .page-num {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 14px;
  color: var(--text-muted);
}

/* ============ BLOCK OPENER ============ */
.block-opener {
  color: white;
  position: relative;
  overflow: hidden;
}
.block-opener .page-inner {
  position: relative;
  z-index: 1;
}
.block-opener-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.block-opener-decor {
  position: absolute;
  width: 380px; height: 380px;
  border-radius: 50%;
  opacity: 0.4;
  bottom: -140px;
  right: -100px;
}

.block-meta {
  display: flex;
  gap: 24px;
  align-items: flex-start;
  margin-bottom: 28px;
}
.block-num-big {
  font-family: var(--font-heading);
  font-weight: 900;
  font-size: var(--fs-block-num);
  line-height: 0.85;
  letter-spacing: -2px;
}
.block-tag-line {
  display: inline-block;
  padding: 4px 12px;
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: 12px;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 14px;
}
.block-title-big {
  font-family: var(--font-heading);
  font-weight: 900;
  font-size: var(--fs-h-chapter);
  text-transform: uppercase;
  line-height: 1;
  margin: 0 0 8px;
}
.block-tagline-big {
  font-family: var(--font-pullquote);
  font-style: italic;
  font-size: 22px;
  margin: 0 0 24px;
  max-width: 600px;
  opacity: 0.95;
}

/* ============ BOXES ============ */
.box { font-family: var(--font-body); font-size: 14.5px; line-height: 1.5; margin: 14px 0; }
.box-body-text { color: var(--text); }

/* Stil B — umlaufender Rahmen (Merksatz, Risiko) */
.box-style-b {
  border: 3px solid;
  border-radius: 6px;
  padding: 14px 18px;
}
.box-style-b .box-head {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: 12px;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 6px;
}

/* Stil C — Header-Streifen (Martin, Sophia, Interview, QR) */
.box-style-c {
  border: 1px solid;
  border-radius: 6px;
  overflow: hidden;
}
.box-style-c .box-head {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: 12px;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 9px 16px;
  color: white;
}
.box-style-c .box-content {
  padding: 14px 18px;
}

/* Stil D — Tag-Label (Praxistipp, Optional, Nächster Schritt) */
.box-style-d {
  position: relative;
  border: 2px solid;
  border-radius: 6px;
  padding: 22px 18px 14px;
  margin-top: 16px;
}
.box-style-d .box-head {
  position: absolute;
  top: -12px;
  left: 16px;
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: 12px;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 4px 14px;
  border-radius: 3px;
  color: white;
}

/* Stil E — breite Akzentleiste (Fehler) */
.box-style-e {
  border: 1px solid rgba(0,0,0,0.1);
  border-left: 14px solid;
  border-radius: 0 6px 6px 0;
  padding: 14px 18px 14px 20px;
}
.box-style-e .box-head {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: 12px;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 6px;
}

/* Box-specific colors */
.box-martin    { background: var(--box-martin-bg);    border-color: var(--box-martin-accent); }
.box-martin .box-head { background: var(--box-martin-accent); color: var(--box-martin-bg); }
.box-martin .box-content { color: var(--box-martin-accent); }
.box-sophia    { background: var(--box-sophia-bg);    border-color: var(--box-sophia-accent); }
.box-sophia .box-head { background: var(--box-sophia-accent); color: var(--box-sophia-bg); }
.box-sophia .box-content { color: var(--box-sophia-accent); }
.box-merksatz  { background: var(--box-merksatz-bg);  border-color: var(--box-merksatz-accent); }
.box-merksatz .box-head { color: var(--box-merksatz-accent); }
.box-praxistipp{ background: var(--box-praxistipp-bg);border-color: var(--box-praxistipp-accent); }
.box-praxistipp .box-head { background: var(--box-praxistipp-accent); color: white; }
.box-risiko    { background: var(--box-risiko-bg);    border-color: var(--box-risiko-accent); }
.box-risiko .box-head { color: var(--box-risiko-accent); }
.box-interview { background: var(--box-interview-bg); border-color: var(--box-interview-accent); }
.box-interview .box-head { background: var(--box-interview-accent); color: var(--box-interview-bg); }
.box-qr        { background: var(--box-qr-bg);        border-color: var(--box-qr-accent); }
.box-qr .box-head { background: var(--box-qr-accent); color: var(--box-qr-bg); }
.box-optional  { background: var(--box-optional-bg);  border-color: var(--box-optional-accent); }
.box-optional .box-head { background: var(--box-optional-accent); color: var(--box-optional-bg); }
.box-naechster { background: var(--box-naechster-bg); border-color: var(--box-naechster-accent); }
.box-naechster .box-head { background: var(--box-naechster-accent); color: white; }
.box-fehler    { background: var(--box-fehler-bg);    border-color: var(--box-fehler-accent); }
.box-fehler .box-head { background: var(--box-fehler-accent); color: var(--box-fehler-bg); }
.box-fehler .box-content { color: var(--box-fehler-accent); }

/* QR box layout */
.box-qr .box-content {
  display: grid;
  grid-template-columns: 1fr 60px;
  gap: 14px;
  align-items: center;
}
.qr-placeholder {
  width: 60px; height: 60px;
  background:
    linear-gradient(45deg, var(--box-qr-accent) 25%, transparent 25%, transparent 75%, var(--box-qr-accent) 75%),
    linear-gradient(45deg, var(--box-qr-accent) 25%, transparent 25%, transparent 75%, var(--box-qr-accent) 75%);
  background-size: 12px 12px;
  background-position: 0 0, 6px 6px;
  border: 2px solid var(--box-qr-accent);
}

/* ============ PULL QUOTE (mittel — heller Bg, Akzent-Border) ============ */
.pullquote {
  font-family: var(--font-pullquote);
  font-style: italic;
  font-size: var(--fs-pullquote);
  line-height: 1.2;
  padding: 16px 24px;
  margin: 18px 0;
  border-left: 6px solid var(--block-deep);
  color: var(--block-deep);
}

/* ============ LIA BANNER ============ */
.lia-banner {
  background: var(--block01-accent);
  color: var(--block01-deep);
  padding: 12px 20px;
  display: flex;
  align-items: center;
  gap: 14px;
  border-radius: 4px;
  margin-bottom: 16px;
}
.lia-banner-icon {
  width: 42px; height: 42px;
  background: var(--block01-deep);
  color: var(--block01-accent);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-cover);
  font-size: 26px;
  flex-shrink: 0;
}
.lia-banner-title {
  font-family: var(--font-heading);
  font-weight: 900;
  font-size: 20px;
  text-transform: uppercase;
  letter-spacing: 1px;
  line-height: 1;
}
.lia-banner-sub {
  font-family: var(--font-body);
  font-size: 13px;
  font-style: italic;
  margin-top: 2px;
}

/* ============ BEISPIEL INLINE ============ */
.beispiel {
  font-family: var(--font-body);
  font-style: italic;
  color: var(--beispiel-blue);
  margin: 14px 0 14px 30px;
  padding-left: 14px;
  border-left: 2px solid var(--beispiel-blue);
  font-size: 14.5px;
  line-height: 1.55;
}
.beispiel b {
  font-style: normal;
  font-weight: 700;
  letter-spacing: 0.5px;
}

/* ============ VARIANTE A SPLIT (Martin/Sophia side by side im Opener) ============ */
.persona-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 8px;
}
.persona-split .box { margin: 0; font-size: 13.5px; }

/* ============ BLOCK-SPEZIFISCHE Variablen-Mapping ============ */
.block-01 { --block-deep: var(--block01-deep); --block-accent: var(--block01-accent); }
.block-02 { --block-deep: var(--block02-deep); --block-accent: var(--block02-accent); }
.block-03 { --block-deep: var(--block03-deep); --block-accent: var(--block03-accent); }
.block-04 { --block-deep: var(--block04-deep); --block-accent: var(--block04-accent); }
