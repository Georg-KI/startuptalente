        </div>

        <div style="margin-top: 14px; padding: 10px 14px; background: rgba(0,0,0,0.04); border-radius: 4px; font-size: 11px; color: var(--text-muted); line-height: 1.5;">
          <strong style="color: var(--text);">Beispiel-Inline-Stil:</strong>
          <span style="font-style: italic; color: var(--beispiel-blue); margin-left: 6px;">
            <b style="font-style: normal; font-weight: 700;">Beispiel:</b> Inline-Format, kursiv, in <span style="font-family: monospace;">#1A5276</span>, eingerückt, mit fettem „Beispiel:"-Lead.
          </span>
        </div>

        <div class="page-footer">
          <div class="block-marker">Referenz · Designsystem</div>
          <div class="page-num">—</div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
// ============ SCALE CONTROL ============
const scaleInput = document.getElementById('scale');
const scaleVal = document.getElementById('scaleVal');
scaleInput.addEventListener('input', () => {
  document.documentElement.style.setProperty('--scale', scaleInput.value);
  scaleVal.textContent = Math.round(scaleInput.value * 100) + '%';
});

// ============ TAB NAVIGATION ============
document.querySelectorAll('.tab-nav button').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-nav button').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
  });
});

// ============ COLOR PICKERS ============
document.querySelectorAll('input[type="color"][data-var]').forEach(input => {
  const hexDisplay = input.parentElement.querySelector('.hex-display');
  input.addEventListener('input', () => {
    document.documentElement.style.setProperty(input.dataset.var, input.value);
    if (hexDisplay) hexDisplay.textContent = input.value.toUpperCase();
  });
});

// ============ TYPOGRAPHY SLIDERS ============
const fsMap = {
  '--fs-body': 'fsBodyVal',
  '--fs-h-chapter': 'fsChapterVal',
  '--fs-block-num': 'fsBlockNumVal',
  '--fs-cover-title': 'fsCoverVal',
  '--fs-pullquote': 'fsPullVal'
};
document.querySelectorAll('input[type="range"][data-var]').forEach(input => {
  input.addEventListener('input', () => {
    const unit = input.dataset.unit || '';
    document.documentElement.style.setProperty(input.dataset.var, input.value + unit);
    const valId = fsMap[input.dataset.var];
    if (valId) document.getElementById(valId).textContent = input.value + unit;
  });
});

// ============ EXPORT ============
function exportHex() {
  const vars = [
    ['Block 01 · Tiefe',           '--block01-deep'],
    ['Block 01 · Akzent',          '--block01-accent'],
    ['Block 02 · Tiefe',           '--block02-deep'],
    ['Block 02 · Akzent',          '--block02-accent'],
    ['Block 03 · Tiefe',           '--block03-deep'],
    ['Block 03 · Akzent',          '--block03-accent'],
    ['Block 04 · Tiefe',           '--block04-deep'],
    ['Block 04 · Akzent',          '--block04-accent'],
    ['Block 05 · Tiefe',           '--block05-deep'],
    ['Block 05 · Akzent',          '--block05-accent'],
    ['Block 06 · Tiefe',           '--block06-deep'],
    ['Block 06 · Akzent',          '--block06-accent'],
    ['',                           ''],
    ['Martin · Bg',                '--box-martin-bg'],
    ['Martin · Akzent',            '--box-martin-accent'],
    ['Sophia · Bg',                '--box-sophia-bg'],
    ['Sophia · Akzent',            '--box-sophia-accent'],
    ['Merksatz · Bg',              '--box-merksatz-bg'],
    ['Merksatz · Akzent',          '--box-merksatz-accent'],
    ['Praxistipp · Bg',            '--box-praxistipp-bg'],
    ['Praxistipp · Akzent',        '--box-praxistipp-accent'],
    ['Risiko · Bg',                '--box-risiko-bg'],
    ['Risiko · Akzent',            '--box-risiko-accent'],
    ['Interview · Bg',             '--box-interview-bg'],
    ['Interview · Akzent',         '--box-interview-accent'],
    ['QR · Bg',                    '--box-qr-bg'],
    ['QR · Akzent',                '--box-qr-accent'],
    ['Optional · Bg',              '--box-optional-bg'],
    ['Optional · Akzent',          '--box-optional-accent'],
    ['Nächster Schritt · Bg',      '--box-naechster-bg'],
    ['Nächster Schritt · Akzent',  '--box-naechster-accent'],
    ['Fehler · Bg',                '--box-fehler-bg'],
    ['Fehler · Akzent',            '--box-fehler-accent'],
    ['',                           ''],
    ['Beispiel-Inline',            '--beispiel-blue'],
    ['Seitenpapier',               '--page-bg']
  ];

  const cs = getComputedStyle(document.documentElement);
  let out = '=== STARTUP TALENTE · FARBEN ===\n\n';
  vars.forEach(([label, v]) => {
    if (!label) { out += '\n'; return; }
    const val = cs.getPropertyValue(v).trim().toUpperCase();
    const padded = label.padEnd(28, ' ');
    out += padded + val + '\n';
  });

  out += '\n=== SCHRIFTEN ===\n\n';
  out += 'Cover-Title       Caveat Brush\n';
  out += 'Headings          Barlow Condensed 900\n';
  out += 'Body              Barlow Regular\n';
  out += 'Pull-Quote        DM Serif Display Italic\n';

  document.getElementById('exportArea').textContent = out;
}
</script>

</body>
</html>
